---js
{
  permalink: 'manifest.webmanifest',
  eleventyExcludeFromCollections: true,
}
---
{
  "name": "{{ site.title }} — {{ site.tagline }}",
  "short_name": "{{ site.title }}",
  "description": "{{ site.description }}",
  "start_url": "{{ '/' | url }}",
  "scope": "{{ '/' | url }}",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#3367D6",
  "icons": [
    {
      "src": "{{ '/assets/icons/icon-192.png' | url }}",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "{{ '/assets/icons/icon-512.png' | url }}",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "{{ '/assets/icons/icon-512.png' | url }}",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
